# 本地开发：API 走 Vite 代理 /api → 线上或本地 PHP（避免 CORS）
VITE_API_BASE=/api
VITE_API_PROXY_TARGET=https://www.vecino.com.ve
# 代理模式：worker=Cloudflare/线上（/api 直连）；index-php=phpstudy 本地
# VITE_API_PROXY_STYLE=worker
# 本地 phpstudy 示例：
# VITE_API_PROXY_TARGET=http://127.0.0.1
# VITE_API_PROXY_STYLE=index-php
VITE_BASE_PATH=/
