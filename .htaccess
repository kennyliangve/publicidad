DirectoryIndex api/index.php index.php index.html

RewriteEngine On
RewriteBase /publicidad/

# 禁止访问 node_modules（防止误传后被下载）
RewriteRule ^frontend/node_modules(/|$) - [F,L]
RewriteRule ^node_modules(/|$) - [F,L]

# 已有真实文件/目录则直接访问
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API 请求
RewriteRule ^api(/.*)?$ api/index.php [QSA,L]

# 兼容旧路径：根目录 install.php → api/install.php
RewriteRule ^install\.php$ api/install.php [R=301,L,QSA]

# 其余请求交给 api/index.php（SPA + 静态资源）
RewriteRule ^ api/index.php [QSA,L]
